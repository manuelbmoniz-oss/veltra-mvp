# ─── Base de Dados (Supabase) ─────────────────────────────────────────────────
# Obter em: Supabase Dashboard → Project → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="SUBSTITUA_POR_SECRET_SEGURO_32_CHARS"

# ─── Resend (emails transacionais) ────────────────────────────────────────────
# Obter em: https://resend.com → API Keys
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXX"

# ─── Supabase Storage (upload de faturas) ─────────────────────────────────────
# Obter em: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6..."
